# ===================================
# A-Share Watchlist Intelligent Analysis System - Environment Variable Configuration Template
# Copy this file to .env and fill in actual configurations
# ===================================

# Watchlist (comma-separated, supports Shanghai and Shenzhen stock codes)
# Shanghai: 600xxx, 601xxx, 603xxx
# Shenzhen: 000xxx, 002xxx, 300xxx
STOCK_LIST=600519,300750,002594

# Anspire Open API Keys (supports multiple, comma-separated)
# Get: https://open.anspire.cn/?share_code=QFBC0FYC
# When no higher-priority OpenAI-compatible source is configured, this key can be reused for Anspire LLM gateway and news search.
# The gateway and model below are example configurations for this project; please verify availability via Anspire console and official docs:
# Example gateway: https://open-gateway.anspire.cn/v6
# Example model: Doubao-Seed-2.0-lite (can be overridden with ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-pro)
# If the gateway has regional/version differences, override with ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.ai/v6
ANSPIRE_API_KEYS=
# ANSPIRE_LLM_MODEL=Doubao-Seed-2.0-lite
# ANSPIRE_LLM_BASE_URL=https://open-gateway.anspire.cn/v6
# ANSPIRE_LLM_ENABLED=true
# Data source configuration
# Tushare Pro Token (optional, get from https://tushare.pro/weborder/#/login?reg=834638)
TUSHARE_TOKEN=
# TickFlow API Key (optional; for A-share daily K-line, real-time quotes, stock list/names and market review enhancement; auto-fallback on insufficient permissions)
# TICKFLOW_API_KEY=
# TICKFLOW_KLINE_ADJUST=none          # none/forward/backward/forward_additive/backward_additive
# TICKFLOW_BATCH_DAILY_ENABLED=true   # Batch pre-fetch daily K-lines via TickFlow when permissions are available
# TICKFLOW_BATCH_SIZE=100             # Maximum number of symbols per TickFlow batch request

# AlphaSift stock screening integration (disabled by default; typically maintained via Web "Enable Screening" button)
ALPHASIFT_ENABLED=false
# Switch description:
# - ALPHASIFT_ENABLED only affects the AlphaSift screening process; it will not modify/migrate/clean existing LITELLM_*/LLM_* configurations.
# - To disable/rollback, simply set ALPHASIFT_ENABLED to false; existing provider/base_url/custom headers and fallback semantics remain unchanged.
# - Compatibility reference (ops verification): LiteLLM providers and OpenAI-compatible semantics are described in the comments below; runtime uses the litellm version pinned in requirements.txt by default.
ALPHASIFT_INSTALL_SPEC=git+https://github.com/ZhuLinsen/alphasift.git@0a7b9cd59e81718f851890535241bc105d4ddc64
# Compatibility notes:
# - ALPHASIFT_INSTALL_SPEC is only used for explicit /api/v1/alphasift/install calls; it will not automatically override historical .env configurations.
# - After upgrading, if you want to use the new pin, clean up the old variable in `.env` then rebuild dependencies/restart the service; or change it to the default value above and rebuild the backend.
# - Only changing this field in .env without rolling back `requirements.txt` and `src/config.py` will trigger an allow-list rejection (alphasift_install_spec_not_allowed).
# AlphaSift full-market snapshot source priority; when not configured, DSA auto-injects based on whether TUSHARE_TOKEN is configured:
# - With TUSHARE_TOKEN: tushare,sina,efinance,akshare_em,em_datacenter
# - Without TUSHARE_TOKEN: sina,efinance,akshare_em,em_datacenter
# SNAPSHOT_SOURCE_PRIORITY=tushare,sina,efinance,akshare_em,em_datacenter
# (If you want to stay consistent with runtime auto-injection, it's recommended to leave this empty and not pin a value in this file)
# AlphaSift latest version supports last-good snapshots, daily history, and industry/concept provider caching; DSA runtime uses the isolated cache directory under data/alphasift by default.
# To customize, override the following paths; leaving empty will not modify existing DSA configurations.
# ALPHASIFT_DATA_DIR=data/alphasift
# ALPHASIFT_FALLBACK_SNAPSHOT_PATH=data/alphasift/snapshot.last_good.json
# ALPHASIFT_DAILY_HISTORY_CACHE_DIR=data/alphasift/daily_history
# ALPHASIFT_INDUSTRY_PROVIDER_CACHE_DIR=data/alphasift/industry_provider_cache
# AlphaSift industry/concept provider is disabled by default; enabling akshare can provide more sector information for theme_heat, industry heat, and LLM context.
# INDUSTRY_PROVIDER=none
# INDUSTRY_PROVIDER_MAX_BOARDS=80
# Single LLM request timeout in seconds; AlphaSift screening reuses this DSA configuration; on timeout, it degrades to non-LLM sorted results.
# LLM_TIMEOUT_SEC=60
# AlphaSift LLM re-ranking request output limit; only affects AlphaSift screening re-ranking, default 2048.
# LLM_MAX_TOKENS=2048

# Finnhub (optional, US stock data source, free tier 60 calls/min)
# Get: https://finnhub.io/register
# FINNHUB_API_KEY=

# AlphaVantage (optional, US stock data source, free tier 25 calls/day)
# Get: https://www.alphavantage.co/support/#api-key
# ALPHAVANTAGE_API_KEY=

# Longbridge OpenAPI (optional, fallback for US/HK stock volume ratio, turnover rate, PE, etc.)
# Get from https://open.longbridge.com/
# OAuth 2.0 (recommended): run scripts/generate_longbridge_oauth_token.py first to generate local SDK token cache
# client_id prioritizes LONGBRIDGE_OAUTH_CLIENT_ID; if empty and no Legacy Access Token, falls back to LONGBRIDGE_APP_KEY for compatibility
# GitHub Actions / Docker can base64-encode the token cache file and set it as LONGBRIDGE_OAUTH_TOKEN_CACHE_B64
# LONGBRIDGE_OAUTH_CLIENT_ID=
# LONGBRIDGE_OAUTH_TOKEN_CACHE_B64=
# Legacy API Key (compatible with legacy accounts; Access Token is not an OAuth access token)
# LONGBRIDGE_APP_KEY=
# LONGBRIDGE_APP_SECRET=
# LONGBRIDGE_ACCESS_TOKEN=
# static_info in-process cache TTL in seconds, default 86400; 0=fetch on every request
# LONGBRIDGE_STATIC_INFO_TTL_SECONDS=86400
# Cooldown seconds after connection-close exceptions, default 15; during cooldown, Longbridge is temporarily skipped to avoid frequent per-request reconnections
# LONGBRIDGE_CONNECTION_COOLDOWN_SECONDS=15
# Longbridge SDK language is consistent with REPORT_LANGUAGE (zh/en); SDK logs are written to LOG_DIR/longbridge_sdk.log
# Access points (independent of REPORT_LANGUAGE; leave empty to use the defaults below):
# LONGBRIDGE_HTTP_URL=https://openapi.longbridge.com
# LONGBRIDGE_QUOTE_WS_URL=wss://openapi-quote.longbridge.com/v2
# LONGBRIDGE_TRADE_WS_URL=wss://openapi-trade.longbridge.com/v2
# LONGBRIDGE_REGION=hk
# Override access points; SDK internally uses LONGPORT_REGION (without BRIDGE) for automatic selection,
# code automatically syncs LONGBRIDGE_REGION → LONGPORT_REGION.
# hk → *.longbridge.com  |  cn → *.longbridge.cn
# For others, see: https://open.longbridge.com/en-US/docs/getting-started#environment-variables
# Overnight market quotes true/false, default false
# LONGBRIDGE_ENABLE_OVERNIGHT=false
# K-line push: realtime or confirmed, default realtime
# LONGBRIDGE_PUSH_CANDLESTICK_MODE=realtime
# Whether to print quote packets on connection (consistent with README / full-guide: when not set, the app defaults to off, equivalent to false)
# Set to 1 / true / yes to enable SDK detailed quote packet logging (use when debugging Longbridge connections)
# LONGBRIDGE_PRINT_QUOTE_PACKAGES=false

# Stock autocomplete index remote update (enabled by default; auto-degrades to local built-in index when GitHub is unreachable)
STOCK_INDEX_REMOTE_UPDATE_ENABLED=true

# ===================================
# AI Model Configuration
# ===================================
# Full documentation: docs/LLM_CONFIG_GUIDE.md
#
# [Quick Start] Fill in one API Key to run; the system auto-detects the model.
#   Anspire Open (all-in-one model+search) → Fill ANSPIRE_API_KEYS
#   Gemini (free quota) → Fill GEMINI_API_KEY
#   DeepSeek (cost-effective) → Fill DEEPSEEK_API_KEY
#   AIHubmix (aggregation platform) → Fill AIHUBMIX_KEY
#
# [Advanced] Multi-model / multi-platform fallback needed → Configure "Multi-Channel" below or manage visually on the Web settings page.
# ===================================

# Generation backend: default litellm; codex_cli is an explicitly opt-in local CLI backend (experimental/limited).
# Local CLI Backend does not mean offline model; the service behind the CLI may process analysis prompts and report drafts.
GENERATION_BACKEND=litellm
# Backend-level fallback; empty local .env disables backend-level fallback, litellm -> litellm is parsed as a no-op.
# Default GitHub Actions workflow uses litellm explicitly when this variable is not configured; to disable fallback in Actions, set to primary backend to achieve self no-op.
GENERATION_FALLBACK_BACKEND=litellm
# Local CLI backend execution limits; max timeout 3600, max output 33554432 bytes, max concurrency 16/4 respectively.
GENERATION_BACKEND_TIMEOUT_SECONDS=300
GENERATION_BACKEND_MAX_OUTPUT_BYTES=1048576
GENERATION_BACKEND_MAX_CONCURRENCY=1
LOCAL_CLI_BACKEND_MAX_CONCURRENCY=1
# Agent Chat backend; Web settings page only exposes auto/litellm; manually writing codex_cli returns unsupported tool-calling diagnostics.
AGENT_GENERATION_BACKEND=auto

# --- API Key (fill in one to start) ---

# Gemini (https://aistudio.google.com)
GEMINI_API_KEY=
# Multi-key load balancing: GEMINI_API_KEYS=key1,key2,key3

# DeepSeek (https://platform.deepseek.com)
# Default compatibility: when only DEEPSEEK_API_KEY is filled, deepseek-chat is still used, with a log message suggesting migration to deepseek-v4-flash
# DEEPSEEK_API_KEY=

# AIHubmix aggregation (https://aihubmix.com/?aff=CfMq)
# One key for GPT/Claude/Gemini/GLM/Qwen and other models, no VPN needed
# AIHUBMIX_KEY=

# Anthropic Claude (https://console.anthropic.com)
# ANTHROPIC_API_KEY=

# OpenAI / Compatible API
# OPENAI_API_KEY=
# OPENAI_BASE_URL=                     # Third-party API address (relay/proxy), leave empty for official

# Ollama local model (no API key needed, recommended)
# OLLAMA_API_BASE=http://localhost:11434
# LITELLM_MODEL=ollama/qwen3:8b
#
# Or use channel mode:
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b

# Sampling temperature (0.0-2.0, default 0.7; 0 = most deterministic, 2 = most random)
# Strict temperature compatibility sources:
# - Moonshot API / model docs: https://platform.kimi.ai/docs/guide/kimi-k2-6-quickstart
# - Moonshot official model card (benchmark default temperature = 1.0): https://huggingface.co/moonshotai/Kimi-K2.6
# - OpenAI Chat Completions spec: https://platform.openai.com/docs/api-reference/chat/create
# - LiteLLM OpenAI-Compatible spec: https://docs.litellm.ai/docs/providers/openai_compatible
# Current repo runtime dependency constraint: litellm>=1.80.10,!=1.82.7,!=1.82.8,<2.0.0 (explicitly excludes PyPI accident versions, see requirements.txt).
# Therefore kimi-k2.6 will automatically use 1.0/0.6; GPT-5 / o-series and other default-temperature models will omit temperature to avoid API rejection.
# If a compatible platform returns an explicit unsupported-parameter error, the runtime will correct the parameter and retry once within the current request; successful strategies are cached in-process only.
# top_p, presence_penalty, frequency_penalty, seed - if "unsupported parameter" is returned, they will also trigger per-request correction and retry (without modifying LLM_TEMPERATURE).
# Other models and fallback still use your configured LLM_TEMPERATURE.
# Web settings page / desktop import will not silently clear or overwrite LLM_TEMPERATURE; only temporarily adapts model parameters before actually sending requests.
# If the primary model switches back to a regular model, the originally configured temperature is automatically restored; minimum rollback is reverting this LLM parameter adaptation change.
# LLM_TEMPERATURE=0.7

# LLM usage telemetry message HMAC configuration (optional)
# When left empty by default, the system generates .llm_usage_hmac_secret in the data directory; stable comparison within local deployments.
# Only configure an explicit shared random secret when cross-deployment usage message HMAC comparison is needed; sync version tag on rotation.
# When explicitly configured, use a high-entropy random value (e.g., openssl rand -hex 32); do not commit real secrets to version control.
# LLM_USAGE_HMAC_SECRET=
# LLM_USAGE_HMAC_KEY_VERSION=local-v1

# Provider prompt cache configuration (optional)
# TELEMETRY only controls provider cache usage / diagnostics logging; does not control provider implicit cache.
# HINTS controls whether to actively send verified provider-specific hints like prompt_cache_key, cache_control, user_id; disabled by default.
# DIAGNOSTICS_LEVEL options: off/basic/debug; debug only outputs desensitized diagnostics, does not log raw prompts or request bodies.
# LLM_PROMPT_CACHE_TELEMETRY_ENABLED=true
# LLM_PROMPT_CACHE_HINTS_ENABLED=false
# LLM_PROMPT_CACHE_DIAGNOSTICS_LEVEL=off

# --- Multi-channel configuration (optional, also configurable on Web settings page) ---
# Each channel independently configures base_url / api_key / models; supports multi-key rotation and automatic fallback.
#
# Example: DeepSeek + Gemini dual channel
# LLM_CHANNELS=deepseek,gemini
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LLM_GEMINI_API_KEYS=key1,key2
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview
#
# Example: Custom API endpoint (third-party proxy / aggregation platform / relay)
# LLM_CHANNELS=my_proxy
# LLM_MY_PROXY_BASE_URL=https://your-proxy.example.com/v1
# LLM_MY_PROXY_API_KEY=sk-xxx
# LLM_MY_PROXY_MODELS=gpt-5.5,claude-sonnet-4-6
# LLM_MY_PROXY_PROTOCOL=openai
#
# Example: Ollama local model (no API key needed)
# LLM_CHANNELS=ollama
# LLM_OLLAMA_BASE_URL=http://localhost:11434
# LLM_OLLAMA_MODELS=qwen3:8b,llama3.2
#
# Example: Hermes local HTTP generation (Phase 3, regular analysis/JSON only; does not support Agent tools, Stream, Vision)
# LLM_CHANNELS=hermes
# LLM_HERMES_PROTOCOL=openai
# LLM_HERMES_BASE_URL=http://127.0.0.1:8642/v1
# LLM_HERMES_API_KEY=sk-local-hermes
# LLM_HERMES_MODELS=hermes-agent
# LITELLM_MODEL=openai/hermes-agent
#
# Common vendor templates (copy any one to .env; full docs at docs/llm-providers.md)
#
# Anspire Open (shared search & LLM key, OpenAI Compatible)
# LLM_CHANNELS=anspire
# LLM_ANSPIRE_PROTOCOL=openai
# LLM_ANSPIRE_BASE_URL=https://open-gateway.anspire.cn/v6 (example)
# LLM_ANSPIRE_API_KEY=sk-xxx
# LLM_ANSPIRE_MODELS=Doubao-Seed-2.0-lite,Doubao-Seed-2.0-pro (example models)
# LITELLM_MODEL=openai/Doubao-Seed-2.0-lite (example)
#
# AIHubmix aggregation platform (OpenAI Compatible)
# LLM_CHANNELS=aihubmix
# LLM_AIHUBMIX_PROTOCOL=openai
# LLM_AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# LLM_AIHUBMIX_API_KEY=sk-xxx
# LLM_AIHUBMIX_MODELS=gpt-5.5,claude-sonnet-4-6,gemini-3.1-pro-preview
# LITELLM_MODEL=openai/gpt-5.5
#
# OpenAI official
# LLM_CHANNELS=openai
# LLM_OPENAI_PROTOCOL=openai
# LLM_OPENAI_BASE_URL=https://api.openai.com/v1
# LLM_OPENAI_API_KEY=sk-xxx
# LLM_OPENAI_MODELS=gpt-5.5,gpt-5.4-mini
# LITELLM_MODEL=openai/gpt-5.5
#
# DeepSeek official
# LLM_CHANNELS=deepseek
# LLM_DEEPSEEK_PROTOCOL=deepseek
# LLM_DEEPSEEK_BASE_URL=https://api.deepseek.com
# LLM_DEEPSEEK_API_KEY=sk-xxx
# LLM_DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro
# LITELLM_MODEL=deepseek/deepseek-v4-flash
#
# Gemini official (official protocol, leave Base URL empty)
# LLM_CHANNELS=gemini
# LLM_GEMINI_PROTOCOL=gemini
# LLM_GEMINI_API_KEY=xxx
# LLM_GEMINI_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview
# LITELLM_MODEL=gemini/gemini-3.1-pro-preview
#
# Anthropic Claude official (official protocol, leave Base URL empty)
# LLM_CHANNELS=anthropic
# LLM_ANTHROPIC_PROTOCOL=anthropic
# LLM_ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_ANTHROPIC_MODELS=claude-sonnet-4-6,claude-opus-4-7
# LITELLM_MODEL=anthropic/claude-sonnet-4-6
#
# Kimi / Moonshot (OpenAI Compatible)
# LLM_CHANNELS=moonshot
# LLM_MOONSHOT_PROTOCOL=openai
# LLM_MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
# LLM_MOONSHOT_API_KEY=sk-xxx
# LLM_MOONSHOT_MODELS=kimi-k2.6,kimi-k2.5
# LITELLM_MODEL=openai/kimi-k2.6
#
# Tongyi Qwen DashScope (OpenAI Compatible)
# LLM_CHANNELS=dashscope
# LLM_DASHSCOPE_PROTOCOL=openai
# LLM_DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_DASHSCOPE_API_KEY=sk-xxx
# LLM_DASHSCOPE_MODELS=qwen3.6-plus,qwen3.6-flash
# LITELLM_MODEL=openai/qwen3.6-plus
#
# Zhipu GLM (OpenAI Compatible)
# LLM_CHANNELS=zhipu
# LLM_ZHIPU_PROTOCOL=openai
# LLM_ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_ZHIPU_API_KEY=xxx
# LLM_ZHIPU_MODELS=glm-5.1,glm-4.7-flash
# LITELLM_MODEL=openai/glm-5.1
#
# MiniMax (OpenAI Compatible)
# Source: Official OpenAI API compatible docs https://platform.minimax.io/docs/api-reference/text-chat
# LiteLLM routes to the compatible Chat Completions Base URL via openai/<model>.
# LLM_CHANNELS=minimax
# LLM_MINIMAX_PROTOCOL=openai
# LLM_MINIMAX_BASE_URL=https://api.minimax.io/v1
# LLM_MINIMAX_API_KEY=xxx
# LLM_MINIMAX_MODELS=MiniMax-M2.7,MiniMax-M2.7-highspeed
# LITELLM_MODEL=openai/MiniMax-M2.7
#
# Xiaomi MiMo (OpenAI Compatible)
# Base URL and model name should follow MiMo official docs/console.
# LLM_CHANNELS=mimo
# LLM_MIMO_PROTOCOL=openai
# LLM_MIMO_BASE_URL=
# LLM_MIMO_API_KEY=sk-xxx
# LLM_MIMO_MODELS=mimo-xxx
# LITELLM_MODEL=openai/mimo-xxx
# Note: The repo's default daily_analysis workflow does not explicitly pass through LLM_MIMO_*; this example is for local .env, Docker, or self-hosted scripts by default; for Actions usage, add corresponding workflow mappings.
#
# Volcengine / Doubao (OpenAI Compatible, adjust endpoint based on your activated region)
# Source: Volcengine online inference / Responses API docs https://www.volcengine.com/docs/82379/2121998
# LiteLLM routes to the compatible Chat Completions Base URL via openai/<model>.
# LLM_CHANNELS=volcengine
# LLM_VOLCENGINE_PROTOCOL=openai
# LLM_VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_VOLCENGINE_API_KEY=xxx
# LLM_VOLCENGINE_MODELS=doubao-seed-1-6-251015,doubao-seed-1-6-thinking-251015
# LITELLM_MODEL=openai/doubao-seed-1-6-251015
#
# SiliconFlow (OpenAI Compatible)
# Source: Official model list https://docs.siliconflow.cn/quickstart/models
# LLM_CHANNELS=siliconflow
# LLM_SILICONFLOW_PROTOCOL=openai
# LLM_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# LLM_SILICONFLOW_API_KEY=sk-xxx
# LLM_SILICONFLOW_MODELS=deepseek-ai/DeepSeek-V3.2,Qwen/Qwen3-235B-A22B-Thinking-2507
# LITELLM_MODEL=openai/deepseek-ai/DeepSeek-V3.2
#
# OpenRouter (OpenAI Compatible)
# Source: Official Models API https://openrouter.ai/docs/api/api-reference/models/get-models
# LLM_CHANNELS=openrouter
# LLM_OPENROUTER_PROTOCOL=openai
# LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# LLM_OPENROUTER_API_KEY=sk-or-xxx
# LLM_OPENROUTER_MODELS=~anthropic/claude-sonnet-latest,~openai/gpt-latest
# LITELLM_MODEL=openai/~anthropic/claude-sonnet-latest

# Advanced: Model routing YAML configuration (optional, see docs/examples/litellm_config.example.yaml)
# LITELLM_CONFIG=./litellm_config.yaml

# ===================================
# Search Engine Configuration (for stock news)
# ===================================
# Bocha API Keys (optimized for Chinese search, supports AI summaries, supports multiple, comma-separated)
# Get: https://open.bocha.cn/
# BOCHA_API_KEYS=your_bocha_key_here
# MiniMax API Key (Coding Plan Web Search, supports multiple, comma-separated)
# Get: https://platform.minimax.io/
# MINIMAX_API_KEYS=your_minimax_key_here
# Tavily API Keys (supports multiple, comma-separated)
TAVILY_API_KEYS=
# SerpAPI Keys (supports multiple, comma-separated)
SERPAPI_API_KEYS=
# Brave Search API Keys (supports multiple, comma-separated)
# Get: https://brave.com/search/api/
BRAVE_API_KEYS=
# SearXNG instance URLs (comma-separated, self-hosted with no quota, requires format: json enabled in settings.yml)
# GitHub Actions daily analysis workflow supports same-name Variables first, Secrets fallback; public URLs can be configured as Variables.
# When empty, defaults to automatically fetching public instances from searx.space; if you don't want to access public instances, set the switch below to false
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true

# ===================================
# Social Sentiment Intelligence (US stocks only)
# ===================================
# Reddit / X (Twitter) / Polymarket sentiment data from api.adanos.org
# Only activates for US stock tickers (AAPL, TSLA, etc.), ignored for A-shares/HK stocks
# Free tier: 250 requests/month | Register: https://api.adanos.org
# SOCIAL_SENTIMENT_API_KEY=sk_live_your_key_here
# SOCIAL_SENTIMENT_API_URL=https://api.adanos.org

# ===================================
# News Timeliness and Analysis Filtering Configuration
# ===================================
# News strategy window profile: ultra_short(1 day) / short(3 days) / medium(7 days) / long(30 days)
# Actual window = min(strategy window, NEWS_MAX_AGE_DAYS)
# NEWS_STRATEGY_PROFILE=short
# News maximum age (days); limits search results to recent ones, avoiding outdated information
# NEWS_MAX_AGE_DAYS=3
# Local news/intelligence pool retention days; only cleans intelligence_items, does not affect historical reports
# NEWS_INTEL_RETENTION_DAYS=30
# Per RSS/Atom news source fetch timeout (seconds)
# NEWS_INTEL_FETCH_TIMEOUT_SEC=8
# Maximum items to collect per news source per fetch
# NEWS_INTEL_MAX_ITEMS_PER_SOURCE=50
# NewsNow HTTP API base URL — external dependency configuration
# - Official project & deployment guide: https://github.com/qqhann/newsnow
# - Current default https://newsnow.busiyi.world is a public example instance with the following risks:
#   * May be unavailable due to official maintenance or rate limiting
#   * No guarantee of stability or data reliability; for demo and testing only
# - Production environments are strongly recommended to use a self-hosted NewsNow instance for controllability and stability
# - Before deployment, verify API contract compatibility (see docs/intelligence-sources.md):
#   curl -sS "https://newsnow.busiyi.world/api/s?id=cls-hot" | python -c "import sys, json; data=json.load(sys.stdin); assert isinstance(data.get('items'), list)"
# - This configuration only controls news source collection and cleanup behavior; does not change LLM / provider / base URL / compatibility fallback semantics
# NEWSNOW_BASE_URL=https://newsnow.busiyi.world
# Deviation rate threshold (%); deviation from MA5 exceeding this value warns against chasing highs; strong trending stocks auto-relax to 1.5x
# BIAS_THRESHOLD=5.0

# ===================================
# Agent Strategy Chat Configuration (Web chat page)
# ===================================
# Enable Agent strategy chat (default false, internally unified as skill)
# AGENT_MODE=true
# Agent primary model (optional): inherits main model when empty; without provider prefix, parsed as openai/<model>
# AGENT_LITELLM_MODEL=
# Agent maximum reasoning steps limit (default 10; each sub-agent runs with its own preset when at default 10; above 10, all sub-agents use this value; below a sub-agent's default, it caps as upper limit)
# AGENT_MAX_STEPS=10
# Default enabled strategies (comma-separated); when not configured, the following built-in defaults are used
#
# Built-in strategy skill list (combine as needed):
#   bull_trend          — Bullish trend (MA5>MA10>MA20 alignment + low deviation rate)
#   ma_golden_cross     — Moving average golden cross (MA5 crosses above MA10/MA20)
#   volume_breakout     — Volume breakout (price breaks recent high + volume surge)
#   hot_theme           — Hot themes (policy/industry hotspots, sector diffusion and stock correlation)
#   event_driven        — Event-driven (earnings, policy, orders, M&A and other catalyst events)
#   growth_quality      — Growth quality (revenue, profit, ROE, cash flow and growth sustainability)
#   expectation_repricing — Expectation repricing (earnings/policy/valuation expectation gap repair or disappointment)
#   shrink_pullback     — Shrinking volume pullback (pullback to moving average + volume contraction, dip-buying point)
#   bottom_volume       — Bottom volume surge (extreme low volume at bottom, reversal signal)
#   dragon_head         — Dragon head strategy (strong leader, trend continuation momentum)
#   one_yang_three_yin  — One yang enclosing three yin (strong reversal after institutional washout pattern)
#   box_oscillation     — Box oscillation (range-bound high-sell low-buy)
#   chan_theory          — Chan theory (Chan Zhongshuo Chan theory: strokes/segments/pivots)
#   wave_theory         — Wave theory (Elliott wave counting)
#   emotion_cycle       — Emotion cycle (market sentiment high/low rotation)
#
# When empty, the system uses the primary default strategy skill declared in metadata (built-in default is bull_trend)
# AGENT_SKILLS=
#
# Or manually specify a set of strategies:
# AGENT_SKILLS=bull_trend,ma_golden_cross,shrink_pullback
#
# Enable all built-in strategies (two equivalent forms):
# AGENT_SKILLS=all
# AGENT_SKILLS=bull_trend,ma_golden_cross,volume_breakout,hot_theme,event_driven,growth_quality,expectation_repricing,shrink_pullback,bottom_volume,dragon_head,one_yang_three_yin,box_oscillation,chan_theory,wave_theory,emotion_cycle
#
AGENT_SKILLS=
# Custom strategy directory (optional, place custom YAML strategy files; env var name follows internal skill naming)
# AGENT_SKILL_DIR=./strategies

# Agent architecture mode (default single; multi for multi-agent orchestration mode)
# AGENT_ARCH=single

# Multi-Agent orchestration mode (only effective when AGENT_ARCH=multi)
# quick: technical analysis → decision (fastest, ~2 LLM calls)
# standard: technical → intelligence → decision (default)
# full: technical → intelligence → risk control → decision
# specialist: technical → intelligence → risk control → strategy specialist evaluation → decision
# AGENT_ORCHESTRATOR_MODE=standard

# Agent execution timeout budget (seconds, 0 = disabled; single-agent used as overall loop budget, multi-agent used as collaboration orchestration budget; default 600)
# AGENT_ORCHESTRATOR_TIMEOUT_S=600

# Whether risk control Agent can veto buy signals (default enabled)
# AGENT_RISK_OVERRIDE=true

# Memory & calibration system (tracks historical accuracy, auto-adjusts confidence)
# AGENT_MEMORY_ENABLED=false

# Auto-weight strategy opinions based on backtest performance
# AGENT_SKILL_AUTOWEIGHT=true

# Strategy routing mode (auto=auto-select based on market state / manual=use AGENT_SKILLS list)
# AGENT_SKILL_ROUTING=auto

# Stock chat visible context compression (disabled by default). When enabled, only compresses visible user/assistant history; does not affect same-turn tool/thinking passthrough.
# AGENT_CONTEXT_COMPRESSION_ENABLED=false
# Compression strategy: cost=fewer tokens / balanced=balanced / long_context_raw_first=prioritize retaining more original text
# AGENT_CONTEXT_COMPRESSION_PROFILE=balanced
# Historical token threshold to trigger compression; leave empty to follow current profile preset
# AGENT_CONTEXT_COMPRESSION_TRIGGER_TOKENS=
# Number of recent user turns and their responses to preserve as original text during compression; leave empty to follow current profile preset
# AGENT_CONTEXT_PROTECTED_TURNS=

# Event alert monitoring (schedule mode background polling; triggered alerts reuse configured notification channels)
# Compatibility note: this section only adds alert rule configuration; it does not modify model names, providers, Base URLs, LiteLLM, or LLM configuration semantics; to rollback, simply disable/remove event monitoring configuration.
# Legacy JSON only supports three types of single-symbol basic rules; technical indicators, watchlist, position/account, and market traffic-light rules should use Web/API alert center configuration.
# Legacy JSON supported rules:
#   price_cross          — Price crossing threshold, direction: above / below, field: price
#   price_change_percent — Price change percentage threshold, direction: up / down, field: change_pct (unit: %)
#   volume_spike         — Volume surge, field: multiplier (multiple relative to 20-day average volume)
# AGENT_EVENT_MONITOR_ENABLED=false
# AGENT_EVENT_MONITOR_INTERVAL_MINUTES=5
# AGENT_EVENT_ALERT_RULES_JSON=[{"stock_code":"600519","alert_type":"price_cross","direction":"above","price":1800},{"stock_code":"300750","alert_type":"price_change_percent","direction":"down","change_pct":3.0},{"stock_code":"000858","alert_type":"volume_spike","multiplier":2.5}]

# ===================================
# Notification Channel Configuration (multiple channels can be configured simultaneously; all will push)
# ===================================
#
# [Method 1] WeCom (Enterprise WeChat) Bot
# In WeCom group -> Settings -> Group Bot -> Add -> Copy Webhook URL
#
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here
#
# [Method 2] Feishu Bot (choose one of two)
#
# Method 2a — Group Custom Bot Webhook
# In Feishu group -> Settings -> Group Bot -> Add Bot -> Custom Bot -> Copy Webhook URL
#
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_key_here
# If the bot security settings have "signature verification" enabled, you need to also fill in the secret
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# If the bot security settings have "keywords" enabled, fill in the same keyword; the system will automatically prepend it to each message
# FEISHU_WEBHOOK_KEYWORD=StockDaily
#
# Method 2b — Feishu App Bot push
# Create an application on Feishu Open Platform, enable im:message permission and publish.
#
# Group chat mode (recommended): Add the bot to the target group, get chat_id from group settings
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
#
# Direct message mode: Send DMs to specified users. Get user open_id from bot events or Contacts API.
# FEISHU_APP_ID=cli_xxxxxxxxxxxxx
# FEISHU_APP_SECRET=your_app_secret
# FEISHU_CHAT_ID=ou_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=open_id
# FEISHU_DOMAIN=feishu  # Domain: feishu (China) / lark (international larksuite.com)
#
# [Method 3] Telegram Bot (requires both items configured)
# 1. Find @BotFather on Telegram -> /newbot -> Get Bot Token
# 2. Get Chat ID: send a message to @userinfobot or visit https://api.telegram.org/bot<token>/getUpdates
#
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_CHAT_ID=123456789
# TELEGRAM_MESSAGE_THREAD_ID=2780
#
# [Method 4] Email push (only 2 items needed, SMTP auto-detected)
# Supports QQ Mail, 163 Mail, Gmail and other mailboxes that support SMTP authorization codes / basic auth
# Outlook / Exchange with tenant-enforced OAuth2 are not supported in the current version
# 1. Get authorization code (QQ Mail example): Settings -> Account -> POP3/SMTP service -> Enable -> Get authorization code
# 2. Fill in the two items below:
#
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_RECEIVERS=receiver@example.com  # Optional, leave empty to send to yourself
#
# [Method 4 Extension] Stock group email routing (Issue #268, optional)
# STOCK_LIST determines the actual analysis scope; STOCK_GROUP_N only determines who receives emails; recommended to always be a subset of STOCK_LIST
# Telegram / WeCom / Webhook and other channels still push based on the full STOCK_LIST, not split by groups
# The current repo's default GitHub Actions daily_analysis workflow does not auto-inject arbitrary STOCK_GROUP_N / EMAIL_GROUP_N
# Therefore this capability applies to local .env, Docker, or other environments that explicitly inject these variables
# STOCK_GROUP_1=600519,300750
# EMAIL_GROUP_1=user1@example.com
# STOCK_GROUP_2=002594,AAPL
# EMAIL_GROUP_2=user2@example.com
#
# [Method 5] Custom Webhook (supports multiple, comma-separated)
# Suitable for: DingTalk, Discord, Slack, Bark, self-hosted services, or any Webhook that supports POST JSON
# The system auto-detects common services and uses the corresponding format
#
# CUSTOM_WEBHOOK_URLS=https://oapi.dingtalk.com/robot/send?access_token=xxx,https://hooks.slack.com/services/xxx
# CUSTOM_WEBHOOK_BEARER_TOKEN=  # Optional, for Webhooks requiring authentication (Header Authorization: Bearer <token>)
# CUSTOM_WEBHOOK_BODY_TEMPLATE=  # Optional, global JSON body template; overrides Bark/Slack/Discord auto payload; recommend $content_json/$title_json
# For Docker Compose hand-written .env, use $$content_json/$$title_json; Web settings page auto-escapes, runtime still restores to single $
# WEBHOOK_VERIFY_SSL=true   # Verify by default; affects webhook-style HTTPS notification requests that read this config. Set to false to support self-signed certs. Warning: disabling exposes MITM hijacking risk; only for trusted intranets
#
# [Method 6] Pushover configuration
# Register Pushover account and create app token https://pushover.net/apps/build
# PUSHOVER_USER_KEY=
# PUSHOVER_API_TOKEN=
#
# [Method 6 Extension] ntfy configuration
# NTFY_URL must include the topic path, e.g., https://ntfy.sh/my-topic or https://self-hosted:port/my-topic
# The system parses the topic and uses the ntfy JSON publish API to send Markdown text.
# NTFY_URL=
# NTFY_TOKEN=  # Optional, for topics or self-hosted ntfy servers requiring Bearer Token
#
# [Method 6 Extension] Gotify configuration
# GOTIFY_URL is the Gotify server base URL, without /message; the system appends /message and sends the token via X-Gotify-Key header.
# GOTIFY_URL=
# GOTIFY_TOKEN=  # Gotify application token
#
# [Method 7] PushPlus configuration (domestic push service, recommended)
# Register PushPlus account and get token https://www.pushplus.plus
# PUSHPLUS_TOKEN=
# Group push: fill in group code, messages are pushed to all subscribed users in the group (one-to-many)
# PUSHPLUS_TOPIC=
#
# [Method 8] Discord configuration
# Supports two methods: Webhook (recommended, simple setup) and Bot API (higher permissions)
# 
# Method 1: Discord Webhook (recommended, no Bot account needed)
# In Discord channel settings -> Integrations -> Webhooks -> New Webhook -> Copy URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token
# 
# Method 2: Discord Bot API (requires Bot account and channel ID)
# 1. Create Bot: https://discord.com/developers/applications -> New Application -> Bot -> Create Bot
# 2. Get Bot Token: Bot page -> Reset Token
# 3. Get Channel ID: Discord enable Developer Mode -> Right-click channel -> Copy ID
# DISCORD_BOT_TOKEN=
# DISCORD_MAIN_CHANNEL_ID=
# DISCORD_CHANNEL_ID=   # Legacy variable name, recommend migrating to DISCORD_MAIN_CHANNEL_ID
# If you want to receive Discord Interaction / Webhook callbacks, you must configure the public key for signature verification
# How to get: Discord Developer Portal -> General Information -> Public Key
# DISCORD_INTERACTIONS_PUBLIC_KEY=
# 
# [Method 9] Slack configuration
# Supports two methods: Bot API (recommended) and Incoming Webhook
# When both are configured, Bot API takes priority to ensure text and images are sent to the same channel.
#
# Method 1: Slack Bot API (recommended, supports image uploads)
# 1. Create Slack App: https://api.slack.com/apps -> Create New App
# 2. Add Bot Token Scopes: chat:write, files:write
# 3. Install to workspace and get Bot Token (xoxb-...)
# 4. Get Channel ID: Channel details -> Copy Channel ID at bottom
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL_ID=C01234567
#
# Method 2: Slack Incoming Webhook (simple setup, no image upload support)
# Create Incoming Webhook on Slack App management page -> Copy URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx
#
# [Method 10] ServerChan 3 configuration (domestic push service, supports WeChat push)
# Register ServerChan 3 account and get SendKey https://sc3.ft07.com/
# SERVERCHAN3_SENDKEY=
#
# [Method 11] AstrBot configuration
# ASTRBOT_URL=
# ASTRBOT_TOKEN=  # Optional, for AstrBot Webhooks requiring Bearer Token
#
# [Advanced] Message length limits (bytes)
# Messages exceeding the limit are automatically sent in batches; generally no need to modify
# FEISHU_MAX_BYTES=20000    # Feishu limit ~20KB, default 20000 bytes
# WECHAT_MAX_BYTES=4000     # WeCom limit 4096 bytes, default 4000 bytes
#
# [Markdown to Image] (Issue #455)
# For channels that don't support Markdown, convert reports to images for better readability
# Single-stock push + image: requires both MARKDOWN_TO_IMAGE_CHANNELS configured and image conversion tool installed
# MARKDOWN_TO_IMAGE_CHANNELS=telegram,wechat,custom,email,slack   # comma-separated
# MARKDOWN_TO_IMAGE_MAX_CHARS=15000   # Skip conversion above this length to avoid oversized images
# MD2IMG_ENGINE=wkhtmltoimage   # wkhtmltoimage(default) | markdown-to-file(better emoji, requires npm i -g markdown-to-file)
# Image conversion tools: wkhtmltopdf (apt install wkhtmltopdf / brew install wkhtmltopdf), or markdown-to-file
#
# [Notification Routing Strategy] (Issue #1200 P3)
# Default empty: that notification type is sent to all configured channels. Fill in to only send to the listed configured channels.
# Allowed values: wechat,feishu,telegram,email,pushover,ntfy,gotify,pushplus,serverchan3,custom,discord,slack,astrbot
# NOTIFICATION_REPORT_CHANNELS=
# NOTIFICATION_ALERT_CHANNELS=
# NOTIFICATION_SYSTEM_ERROR_CHANNELS=
#
# [Notification Noise Reduction] (Issue #1200 P4)
# All disabled by default; only affects static notification channels, does not affect bot-triggered conversation receipts.
# NOTIFICATION_DEDUP_TTL_SECONDS=0      # Same stable dedup key is sent only once within TTL; 0 = disabled
# NOTIFICATION_COOLDOWN_SECONDS=0       # Same cooldown key is rate-limited within window; 0 = disabled
# NOTIFICATION_QUIET_HOURS=             # Quiet hours, format HH:MM-HH:MM, supports crossing midnight
# NOTIFICATION_TIMEZONE=                # Quiet hours timezone, e.g., Asia/Shanghai; leave empty to follow TZ/system local timezone
# NOTIFICATION_MIN_SEVERITY=            # info,warning,error,critical; leave empty to keep current behavior
# NOTIFICATION_DAILY_DIGEST_ENABLED=false  # Reserved config; daily digest is not currently sent
#
# [Real-time Quote Pre-fetch] (Issue #455)
# PREFETCH_REALTIME_QUOTES=true   # Set to false to disable, avoiding efinance/akshare_em full-market fetch; tushare is per-symbol, pre-fetch only fetches the first stock

# ===================================
# Single-Stock Push Configuration (optional)
# ===================================
# Single-stock push mode: push immediately after each stock is analyzed, rather than pushing after all are summarized
# SINGLE_STOCK_NOTIFY=false
#
# Report type: simple (concise), full (complete), brief (3-5 sentence summary)
# If push content is incomplete in Docker environments, you can set it to full
# REPORT_TYPE=simple
# Report output language: en (English, default) / zh (Chinese) / ko (Korean)
# REPORT_LANGUAGE=en
# Analysis results summary only: set to true to push only the summary, without individual stock details
# REPORT_SUMMARY_ONLY=false
# Show LLM model name used for this analysis at the bottom of notification reports; set to false to hide
# REPORT_SHOW_LLM_MODEL=true
#
# Report Engine P0 (Jinja2 / Integrity Check / Historical Comparison)
# REPORT_TEMPLATES_DIR=templates
# REPORT_RENDERER_ENABLED=false
# REPORT_INTEGRITY_ENABLED=true
# REPORT_INTEGRITY_RETRY=1
# REPORT_HISTORY_COMPARE_N=0

# Merge individual stock analysis and market review into one push (default false), reduces email count and spam risk
# MERGE_EMAIL_NOTIFICATION=false

# ===================================
# Analysis Interval Configuration (optional)
# ===================================
# Delay between individual stock analysis and market analysis (seconds)
# Used to avoid triggering rate limits of Gemini and other AI APIs
# ANALYSIS_DELAY=0

# App Key (shared with Webhook mode)
DINGTALK_APP_KEY=xxxx
# App Secret (shared with Webhook mode)
DINGTALK_APP_SECRET=xxxx
# Enable Stream mode
DINGTALK_STREAM_ENABLED=false

# Feishu App configuration (for App Bot active push / Stream Bot / Cloud Documents; does not directly enable group Webhook push)
FEISHU_APP_ID=xxxx
FEISHU_APP_SECRET=xxxx  # App Bot active push also requires FEISHU_CHAT_ID; for simple group push, prefer FEISHU_WEBHOOK_URL
# App Bot active push target; Stream Bot or cloud documents do not need this
# FEISHU_CHAT_ID=oc_xxxxxxxxxxxxx
# FEISHU_RECEIVE_ID_TYPE=chat_id
# Enable long connection mode
FEISHU_STREAM_ENABLED=false
# Feishu group bot Webhook security configuration (only used for Webhook push mode)
# FEISHU_WEBHOOK_SECRET=your_feishu_webhook_secret
# FEISHU_WEBHOOK_KEYWORD=StockDaily

# Database path
DATABASE_PATH=./data/stock_analysis.db
# SQLite write optimization: WAL enabled by default for file-based databases, reducing lock contention during batch writes and concurrent writebacks
SQLITE_WAL_ENABLED=true
# SQLite lock wait timeout (milliseconds)
SQLITE_BUSY_TIMEOUT_MS=5000
# Maximum retry count for SQLite on "database is locked" / "database table is locked" errors
SQLITE_WRITE_RETRY_MAX=3
# SQLite write retry base backoff time (seconds, increases exponentially)
SQLITE_WRITE_RETRY_BASE_DELAY=0.1

# Analysis history snapshot: set to false to not persist the full context_snapshot
# Includes enhanced_context, market_phase_summary, AnalysisContextPack overview, diagnostics, and raw snapshot fields
SAVE_CONTEXT_SNAPSHOT=true

# ===================================
# Backtest Configuration (optional)
# ===================================
# Enable backtesting (true/false)
BACKTEST_ENABLED=true
# Backtest evaluation window (trading days)
BACKTEST_EVAL_WINDOW_DAYS=10
# Only backtest analysis records older than N days (to avoid incomplete data for today/recent days)
BACKTEST_MIN_AGE_DAYS=14
# Backtest engine version (used to distinguish results when backtest logic is upgraded)
BACKTEST_ENGINE_VERSION=v1
# Neutral band threshold (%), e.g., 2 means -2%~+2% is considered sideways
BACKTEST_NEUTRAL_BAND_PCT=2.0

# === Scheduled Task Configuration ===
# Enable scheduled tasks (true/false)
SCHEDULE_ENABLED=false
# Daily execution time (HH:MM format, 24-hour)
SCHEDULE_TIME=18:00
# Multiple execution times list (comma-separated; when empty, SCHEDULE_TIME is used)
SCHEDULE_TIMES=
# Whether to run analysis once immediately on scheduled mode startup (true/false)
# If not explicitly set, scheduled mode follows RUN_IMMEDIATELY runtime override semantics for backward compatibility
SCHEDULE_RUN_IMMEDIATELY=true
# Whether to run analysis once immediately on non-scheduled mode startup (true/false)
RUN_IMMEDIATELY=true
# Enable market review (true/false)
MARKET_REVIEW_ENABLED=true
# Inject market environment summary into individual stock analysis Prompt and enable guard rails (true/false, default enabled)
DAILY_MARKET_CONTEXT_ENABLED=true
# Market review regions: cn (A-shares), hk (HK stocks), us (US stocks), jp (Japan stocks), kr (Korea stocks), both (all markets);
# Supports comma-separated subsets (e.g., cn,us,kr); invalid/empty values fall back to cn. cn/hk/us/jp/kr are for users focusing on a single region
# MARKET_REVIEW_REGION=cn
# Market review index up/down color: green_up=green for up, red for down (default), red_up=red for up, green for down
# MARKET_REVIEW_COLOR_SCHEME=green_up

# ===================================
# Proxy Configuration (optional)
# ===================================
# Enable proxy (true/false, default false)
# Only effective in local development; GitHub Actions environment automatically skips
USE_PROXY=false
# Proxy server address (default 127.0.0.1)
PROXY_HOST=127.0.0.1
# Proxy server port (default 10809)
PROXY_PORT=10809

# System configuration
# Log directory
LOG_DIR=./logs
# Log level (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO
# LiteLLM internal log level (DEBUG/INFO/WARNING/ERROR/CRITICAL; default WARNING; temporarily set to DEBUG when troubleshooting internal streaming/routing details)
# LITELLM_LOG_LEVEL=WARNING
# Maximum concurrent threads (recommend keeping low concurrency to avoid bans)
MAX_WORKERS=3
# Enable debug logging
DEBUG=false

# ===================================
# WebUI Configuration (optional)
# ===================================
# Launch WebUI by default (true/false, default false)
WEBUI_ENABLED=false
# WebUI listen address (default 127.0.0.1; Docker/cloud servers need 0.0.0.0 for external access, see docs/deploy-webui-cloud.md)
WEBUI_HOST=127.0.0.1
# WebUI listen port (default 8000)
WEBUI_PORT=8000
# Auto-build frontend before starting web service (npm install && npm run build, default true)
WEBUI_AUTO_BUILD=true
# Trust X-Forwarded-For for real IP under a single trusted reverse proxy (e.g., Nginx → App), takes the rightmost value for login rate limiting; multi-level proxy/CDN scenarios may degrade rate limit key to edge proxy IP, requiring additional evaluation; keep false for direct public access to prevent spoofing
# TRUST_X_FORWARDED_FOR=false

# ===================================
# Web Login Authentication (optional)
# ===================================
# Set to true to enable password protection; set initial password on first web access, changeable in "System Settings > Change Password"
# Forgot password: run on server: python -m src.auth reset_password
ADMIN_AUTH_ENABLED=false
# ADMIN_SESSION_MAX_AGE_HOURS=24  # Session validity period (hours)

# ===========================================
# Image Stock Code Recognition (Settings page "Add from Image")
# ===========================================
# Single request timeout 60 seconds; max image size 5MB
# Requires at least one of GEMINI_API_KEY, ANTHROPIC_API_KEY, or OPENAI_API_KEY (Vision-capable model)

# ===========================================
# Data Fetcher Priority Configuration
# ===========================================
# Lower number = higher priority (tried first)
# Default priorities: efinance(0) > akshare(1) > tushare/pytdx(2) > baostock(3) > yfinance(4)
# For US stocks, set YFINANCE_PRIORITY=0 to use Yahoo Finance first

# EFINANCE_PRIORITY=0      # EastMoney (China) - default: 0
# EFINANCE_CALL_TIMEOUT=30 # Timeout (seconds) for efinance API calls; prevents indefinite hangs
#                          # when eastmoney hosts are unreachable. Default: 30
# AKSHARE_PRIORITY=1       # AkShare (China) - default: 1
# TUSHARE_PRIORITY=2       # Tushare Pro (China) - default: 2
# TICKFLOW_PRIORITY=2      # TickFlow (A-shares) - default: 2; optional, requires TICKFLOW_API_KEY
# PYTDX_PRIORITY=2         # Tongdaxin (China) - default: 2
#
# Pytdx custom server (for intranet/deploy): use custom host instead of built-in public servers
# PYTDX_HOST=192.168.1.100
# PYTDX_PORT=7709
# Or multiple servers: PYTDX_SERVERS=ip1:port1,ip2:port2
# BAOSTOCK_PRIORITY=3      # Baostock (China) - default: 3
# YFINANCE_PRIORITY=4      # Yahoo Finance (Global) - default: 4

# Example: Prioritize Yahoo Finance for US stocks
# YFINANCE_PRIORITY=0
# EFINANCE_PRIORITY=99

# ===========================================
# Real-time Quote Data Source Priority Configuration
# ===========================================
# Used to fetch volume ratio, turnover rate, P/E ratio and other real-time data
# Available data sources (comma-separated, tried in order):
#   - tencent: Tencent Finance, has volume ratio/turnover rate/PE/PB, stable single-stock queries (recommended first)
#   - akshare_sina: Sina Finance, basic quotes, no volume ratio, but very stable
#   - efinance: EastMoney (efinance lib), has volume ratio, full-market fetch prone to bans
#   - akshare_em: EastMoney (akshare lib), most complete data, full-market fetch prone to bans
#   - tickflow: TickFlow, optional; supports batch pre-fetch by current symbols when ranked in top two priorities
#   - tushare: Tushare Pro, requires 2000 points, comprehensive data (recommended for paid users)
#
# Default priority: tencent > akshare_sina > efinance > akshare_em
# If you have a high-point Tushare Pro account, you can put tushare first:
# REALTIME_SOURCE_PRIORITY=tickflow,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tushare,tencent,akshare_sina,efinance,akshare_em
# REALTIME_SOURCE_PRIORITY=tencent,akshare_sina,efinance,akshare_em

# Enable real-time quotes (when disabled, analysis uses historical closing prices)
# ENABLE_REALTIME_QUOTE=true

# Intraday real-time technical indicators: when enabled, uses real-time price to calculate MA/bullish alignment (Issue #234); when disabled, uses previous day's close
# ENABLE_REALTIME_TECHNICAL_INDICATORS=true

# Enable chip distribution (this API is unstable; recommended to disable for cloud deployments)
# ENABLE_CHIP_DISTRIBUTION=true

# Enable fundamentals aggregation (new P0 capability)
# ENABLE_FUNDAMENTAL_PIPELINE=true

# Fundamentals aggregation performance and stability parameters (unit: seconds)
# FUNDAMENTAL_STAGE_TIMEOUT_SECONDS=8.0
# FUNDAMENTAL_FETCH_TIMEOUT_SECONDS=3.0
# FUNDAMENTAL_RETRY_MAX=1
# FUNDAMENTAL_CACHE_TTL_SECONDS=120
# FUNDAMENTAL_CACHE_MAX_ENTRIES=256

# ===========================================
# Portfolio P0: Import / Risk / FX Degradation Configuration
# ===========================================
# PORTFOLIO_RISK_CONCENTRATION_ALERT_PCT=35.0
# PORTFOLIO_RISK_DRAWDOWN_ALERT_PCT=15.0
# PORTFOLIO_RISK_STOP_LOSS_ALERT_PCT=10.0
# PORTFOLIO_RISK_STOP_LOSS_NEAR_RATIO=0.8
# PORTFOLIO_RISK_LOOKBACK_DAYS=180
# PORTFOLIO_FX_UPDATE_ENABLED=true

# EastMoney API patch: recommended to enable when EastMoney/Efinance/Akshare EastMoney APIs frequently fail (RemoteDisconnected, connection closed)
# When enabled, injects NID token and random User-Agent to reduce the chance of being rate-limited by EastMoney
# ENABLE_EASTMONEY_PATCH=false
